RewriteEngine On
# Evitar que se listen listas de directorios si no hay index
Options -Indexes

# Redireccionar y servir archivos internos ocultando la terminacion .html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L,QSA]
